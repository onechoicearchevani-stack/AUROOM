# ── Aurum Restaurant — environment configuration ─────────────────
# Copy this file to ".env" and change EVERY secret value before deploying.

# Port the server listens on
PORT=3000

# Public URL of the site (used for CORS / links). No trailing slash.
SITE_URL=http://localhost:3000

# Secret used to sign login tokens. MUST be long & random in production.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string

# How long a staff login stays valid
JWT_EXPIRES_IN=12h

# Anyone who wants to register a NEW admin/staff account must know this code.
# This prevents random visitors from creating staff accounts.
ADMIN_REGISTRATION_CODE=aurum-staff-2024

# Set to "production" on your live server
NODE_ENV=development

# ── Storage locations (optional) ─────────────────────────────────
# Leave unset locally. In production with a persistent volume (e.g. Railway),
# point these at the mounted volume so data survives redeploys:
#   DATA_DIR=/data
#   UPLOADS_DIR=/data/uploads
